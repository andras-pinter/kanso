{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kanso",
  "version": "0.1.0",
  "identifier": "dev.kanso.desktop",
  "build": {
    "beforeDevCommand": "bash -c 'bash \"$(git rev-parse --show-toplevel)/crates/kanso-tauri/scripts/ui.sh\" dev'",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bash -c 'bash \"$(git rev-parse --show-toplevel)/crates/kanso-tauri/scripts/ui.sh\" build'",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "kanso",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Personal local-first kanban",
    "longDescription": "kanso — personal, local-first kanban with rich-text cards.",
    "resources": {
      "resources/extensions": "extensions"
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "infoPlist": "Info.plist"
    }
  }
}
