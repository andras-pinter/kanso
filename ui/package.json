{
  "name": "kanso-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild:editor:dev": "node scripts/prebuild-editor-dev.mjs --force",
    "build": "tsc -b && vite build && node scripts/check-bundle-size.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@blocksuite/affine": "^0.22.4",
    "@blocksuite/integration-test": "^0.22.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tauri-apps/api": "^2.11.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "yjs": "^13.6.31",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "happy-dom": "^15.11.7",
    "prettier": "^3.4.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.0.3",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.11"
  },
  "//": "LOCKED: vite must stay on ^6.x — Vite 7+/Rolldown breaks vanilla-extract decorator parsing in transitive BlockSuite imports. See ui/README.md.",
  "//tech-debt": "@blocksuite/integration-test is a test package consumed as a production dep — it's the only working reference for TestAffineEditorContainer. See ui/README.md."
}
